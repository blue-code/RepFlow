default_platform(:ios)

platform :ios do

  before_all do
    setup_ci if ENV["CI"]
  end

  desc "App Store Connect API 인증"
  private_lane :authenticate do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      duration: 1200,
      in_house: false
    )
  end

  desc "App Store Connect에 앱 등록"
  lane :create_app do
    authenticate

    create_app_online(
      app_identifier: "com.repflow.app",
      app_name: "RepFlow",
      language: "ko",
      sku: "com.repflow.app.001",
      team_id: ENV["TEAM_ID"],
      platforms: ["ios"],
      skip_devcenter: false
    )
  end

  desc "TestFlight에 새 빌드 업로드"
  lane :beta do
    authenticate

    if ENV["AUTO_INCREMENT_BUILD_NUMBER"] == "true"
      increment_build_number(
        build_number: latest_testflight_build_number + 1,
        xcodeproj: "RepFlow.xcodeproj"
      )
    end

    build_app(
      project: "RepFlow.xcodeproj",
      scheme: "RepFlow",
      clean: true,
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: ENV["TEAM_ID"]
      },
      export_xcargs: "-allowProvisioningUpdates",
      xcargs: "-allowProvisioningUpdates",
      output_directory: "./build",
      output_name: "RepFlow.ipa"
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      changelog: changelog_from_git_commits(
        commits_count: 10,
        pretty: "- %s",
        merge_commit_filtering: "exclude_merges"
      )
    )

    clean_build_artifacts
  end

  desc "빌드만 실행 (업로드 없이)"
  lane :build_only do
    build_app(
      project: "RepFlow.xcodeproj",
      scheme: "RepFlow",
      clean: true,
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: ENV["TEAM_ID"]
      },
      export_xcargs: "-allowProvisioningUpdates",
      xcargs: "-allowProvisioningUpdates",
      output_directory: "./build",
      output_name: "RepFlow.ipa"
    )
  end

  desc "유닛 테스트"
  lane :test do
    run_tests(
      project: "RepFlow.xcodeproj",
      scheme: "RepFlow",
      devices: ["iPhone 17"],
      clean: true
    )
  end
end
